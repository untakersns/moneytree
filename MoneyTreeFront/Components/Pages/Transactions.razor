@page "/transactions"
@layout MainLayout
@inject TransactionService TransactionService
@inject CategoryService CategoryService

<PageTitle>Транзакции - MoneyTree</PageTitle>

@if (!isAuthenticated)
{
    <div class="loading-container">
        <p>Для просмотра этой страницы необходимо войти в систему</p>
        <a href="/login" class="btn btn-primary">Войти</a>
    </div>
}
else
{
<div class="transactions-page">
    <div class="page-header">
        <h1>Транзакции</h1>
        <button class="btn btn-primary" @onclick="ToggleForm">
            @(ShowForm ? "Скрыть форму" : "+ Добавить транзакцию")
        </button>
    </div>

    @if (ShowForm)
    {
        <div class="form-card">
            <h2>@(editingTransaction == null ? "Новая транзакция" : "Редактировать транзакцию")</h2>
            
            <EditForm Model="transactionForm" OnValidSubmit="CreateTransaction">
                <DataAnnotationsValidator />
                
                <div class="form-row">
                    <div class="form-group">
                        <label for="type">Тип</label>
                        <InputSelect id="type" class="form-control" @bind-Value="SelectedType">
                            <option value="Expense">Расход</option>
                            <option value="Income">Доход</option>
                        </InputSelect>
                        <ValidationMessage For="@(() => transactionForm.Type)" />
                    </div>
                    
                    <div class="form-group">
                        <label for="amount">Сумма</label>
                        <InputNumber id="amount" class="form-control" @bind-Value="transactionForm.Amount" step="0.01" />
                        <ValidationMessage For="@(() => transactionForm.Amount)" />
                    </div>
                </div>
                
                <div class="form-row">
                    <div class="form-group">
                        <label for="categoryId">Категория</label>
                        <InputSelect id="categoryId" class="form-control" @bind-Value="transactionForm.CategoryId">
                            @foreach (var cat in filteredCategories)
                            {
                                <option value="@cat.Id">@cat.Name</option>
                            }
                        </InputSelect>
                        <ValidationMessage For="@(() => transactionForm.CategoryId)" />
                    </div>
                    
                    <div class="form-group">
                        <label for="date">Дата</label>
                        <InputDate id="date" class="form-control" @bind-Value="transactionForm.Date" />
                        <ValidationMessage For="@(() => transactionForm.Date)" />
                    </div>
                </div>
                
                <div class="form-group">
                    <label for="comment">Комментарий</label>
                    <InputText id="comment" class="form-control" @bind-Value="transactionForm.Comment" />
                    <ValidationMessage For="@(() => transactionForm.Comment)" />
                </div>
                
                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="error-message">@errorMessage</div>
                }
                
            <div class="form-actions">
                    <button type="button" class="btn btn-secondary" @onclick="ToggleForm">Отмена</button>
                    @if (editingTransaction == null)
                    {
                        <button type="submit" class="btn btn-primary" disabled="@(isSubmitting)">
                            @(isSubmitting ? "Сохранение..." : "Сохранить")
                        </button>
                    }
                    else
                    {
                        <button type="button" class="btn btn-primary" @onclick="UpdateTransaction" disabled="@(isSubmitting)">
                            @(isSubmitting ? "Обновление..." : "Обновить")
                        </button>
                    }
                </div>
            </EditForm>
        </div>
    }

    @if (isLoading)
    {
        <div class="loading-container">
            <div class="spinner"></div>
            <p>Загрузка...</p>
        </div>
    }
    else if (transactions.Any())
    {
        <div class="transactions-table">
            <table>
                 <thead>
                    <tr>
                        <th>Дата</th>
                        <th>Категория</th>
                        <th>Тип</th>
                        <th>Сумма</th>
                        <th>Комментарий</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in transactions.OrderByDescending(x => x.Date))
                    {
                        <tr class="transaction-row @(t.Type.ToLower())">
                            <td>@t.Date.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>
                                <span class="category-badge">@t.CategoryName</span>
                            </td>
                            <td>
                                <span class="type-badge @(t.Type.ToLower())">
                                    @(t.Type.ToLower() == "income" ? "Доход" : "Расход")
                                </span>
                            </td>
                            <td class="amount @(t.Type.ToLower() == "income" ? "positive" : "negative")">
                                @(t.Type.ToLower() == "income" ? "+" : "-") @t.Amount.ToString("N2") RUB
                            </td>
                            <td class="comment">@t.Comment</td>
                            <td class="actions-cell">
                                <button class="btn btn-sm btn-outline-primary" @onclick="() => StartEditTransaction(t)">
                                    ✏️
                                </button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteTransaction(t.Id)">
                                    🗑️
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="empty-state">
            <div class="empty-icon">💸</div>
            <h3>Транзакций пока нет</h3>
            <p>Добавьте первую транзакцию</p>
        </div>
    }
</div>
}

@code {
    private bool isLoading = true;
    private bool isAuthenticated = false;
    private bool ShowForm = false;
    private bool isSubmitting = false;
    private string errorMessage = "";
    private List<TransactionDto> transactions = new();
    private List<CategoryDto> allCategories = new();
    private List<CategoryDto> filteredCategories = new();
    
    private TransactionFormModel transactionForm = new();
    
    private string SelectedType
    {
        get => transactionForm.Type;
        set
        {
            transactionForm.Type = value;
            FilterCategories();
        }
    }

    [Inject] private AuthService AuthService { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        isAuthenticated = await AuthService.IsAuthenticatedAsync();
        
        if (!isAuthenticated)
        {
            isLoading = false;
            return;
        }
        
        await LoadData();
    }

    private void ToggleForm()
    {
        ShowForm = !ShowForm;
        if (ShowForm)
        {
            transactionForm = new TransactionFormModel
            {
                Type = "Expense",
                Date = DateTime.UtcNow
            };
            FilterCategories();
        }
    }

    private async Task LoadData()
    {
        isLoading = true;
        
        try
        {
            transactions = await TransactionService.GetAllAsync();
            allCategories = await CategoryService.GetAllAsync();
            FilterCategories();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void FilterCategories()
    {
        var selectedType = transactionForm.Type?.ToLower() ?? "expense";

        filteredCategories = allCategories
            .Where(c => c.Type.ToLower() == selectedType)
            .ToList();

        if (!filteredCategories.Any())
        {
            filteredCategories = allCategories;
        }

        // Автоматически выбираем первую категорию из отфильтрованного списка
        if (filteredCategories.Any())
        {
            transactionForm.CategoryId = filteredCategories[0].Id;
            StateHasChanged(); // Обновляем UI
        }
    }

    private async Task CreateTransaction()
    {
        isSubmitting = true;
        errorMessage = "";

        try
        {
            var createDto = new CreateTransactionDto
            {
                Amount = transactionForm.Amount,
                Date = transactionForm.Date,
                Type = transactionForm.Type,
                CategoryId = transactionForm.CategoryId,
                Comment = transactionForm.Comment
            };

            await TransactionService.CreateAsync(createDto);

            ShowForm = false;
            transactionForm = new();
            await LoadData();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task DeleteTransaction(int transactionId)
    {
        try
        {
            await TransactionService.DeleteAsync(transactionId);
            await LoadData();
        }
        catch (Exception ex)
        {
            errorMessage = $"Ошибка удаления: {ex.Message}";
        }
    }

    private TransactionDto? editingTransaction = null;

    private void StartEditTransaction(TransactionDto transaction)
    {
        editingTransaction = transaction;
        transactionForm = new TransactionFormModel
        {
            Type = transaction.Type,
            Amount = transaction.Amount,
            CategoryId = transaction.CategoryId,
            Date = transaction.Date,
            Comment = transaction.Comment
        };
        ShowForm = true;
        FilterCategories();
    }

    private async Task UpdateTransaction()
    {
        if (editingTransaction == null) return;

        isSubmitting = true;
        errorMessage = "";

        try
        {
            var updateDto = new UpdateTransactionDto
            {
                Amount = transactionForm.Amount,
                Date = transactionForm.Date,
                Type = transactionForm.Type,
                CategoryId = transactionForm.CategoryId,
                Comment = transactionForm.Comment
            };

            await TransactionService.UpdateAsync(editingTransaction.Id, updateDto);

            ShowForm = false;
            editingTransaction = null;
            transactionForm = new();
            await LoadData();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private class TransactionFormModel
    {
        [Required(ErrorMessage = "Выберите тип")]
        public string Type { get; set; } = "Expense";
        
        [Required(ErrorMessage = "Введите сумму")]
        [Range(0.01, double.MaxValue, ErrorMessage = "Сумма должна быть больше 0")]
        public decimal Amount { get; set; }
        
        [Required(ErrorMessage = "Выберите категорию")]
        public int CategoryId { get; set; }
        
        [Required(ErrorMessage = "Выберите дату")]
        public DateTime Date { get; set; } = DateTime.UtcNow;
        
        public string? Comment { get; set; }
    }
}
