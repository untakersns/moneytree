@page "/register"
@layout MainLayout
@inject AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Регистрация - MoneyTree</PageTitle>

<div class="login-container">
    <div class="login-card">
        <h1>Регистрация</h1>

        <EditForm Model="registerModel" OnValidSubmit="HandleRegister">
            <DataAnnotationsValidator />

            <div class="form-group">
                <label for="email">Email</label>
                <InputText id="email"
                           class="form-control"
                           @bind-Value="registerModel.Email" />
                <ValidationMessage For="@(() => registerModel.Email)" />
            </div>

            <div class="form-group">
                <label for="password">Пароль</label>
                <InputText id="password"
                           type="password"
                           class="form-control"
                           @bind-Value="registerModel.Password" />
                <ValidationMessage For="@(() => registerModel.Password)" />
            </div>

            <div class="form-group">
                <label for="confirmPassword">Подтверждение пароля</label>
                <InputText id="confirmPassword"
                           type="password"
                           class="form-control"
                           @bind-Value="registerModel.ConfirmPassword" />
                <ValidationMessage For="@(() => registerModel.ConfirmPassword)" />
            </div>

            <div class="form-group">
                <label for="currency">Валюта</label>
                <InputSelect id="currency" class="form-control" @bind-Value="registerModel.Currency">
                    <option value="RUB">RUB</option>
                    <option value="USD">USD</option>
                    <option value="EUR">EUR</option>
                </InputSelect>
                <ValidationMessage For="@(() => registerModel.Currency)" />
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="error-message">@errorMessage</div>
            }

            <button type="submit" class="btn btn-primary" disabled="@(isSubmitting)">
                @if (isSubmitting)
                {
                    <span>Регистрация...</span>
                }
                else
                {
                    <span>Зарегистрироваться</span>
                }
            </button>
        </EditForm>

        <div class="login-footer">
            <p>Уже есть аккаунт? <a href="/login">Войти</a></p>
        </div>
    </div>
</div>

@code {
    private RegisterModel registerModel = new();
    private string errorMessage = "";
    private bool isSubmitting;

    private async Task HandleRegister()
    {
        isSubmitting = true;
        errorMessage = "";

        try
        {
            await AuthService.RegisterAsync(registerModel.Email, registerModel.Password, registerModel.Currency);
            // Перезагружаем страницу для обновления состояния
            Navigation.NavigateTo("/", forceLoad: true);
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private class RegisterModel
    {
        [Required(ErrorMessage = "Email обязателен")]
        [EmailAddress(ErrorMessage = "Неверный формат email")]
        public string Email { get; set; } = "";

        [Required(ErrorMessage = "Пароль обязателен")]
        [MinLength(6, ErrorMessage = "Пароль должен быть не менее 6 символов")]
        public string Password { get; set; } = "";

        [Required(ErrorMessage = "Подтверждение пароля обязательно")]
        [Compare("Password", ErrorMessage = "Пароли не совпадают")]
        public string ConfirmPassword { get; set; } = "";

        public string Currency { get; set; } = "RUB";
    }
}
