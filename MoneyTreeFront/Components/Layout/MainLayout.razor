@using Microsoft.AspNetCore.Components.Authorization
@inherits LayoutComponentBase

<AuthorizeView>
    <Authorized>
        <div class="app-container">
            <nav class="sidebar">
                <div class="sidebar-header">
                    <h3>💰 MoneyTree</h3>
                </div>

                <div class="nav-menu">
                    <a class="nav-item" href="/" match="NavLinkMatch.All">
                        <span class="nav-icon">📊</span>
                        <span>Dashboard</span>
                    </a>
                    <a class="nav-item" href="/transactions">
                        <span class="nav-icon">💳</span>
                        <span>Транзакции</span>
                    </a>
                    <a class="nav-item" href="/categories">
                        <span class="nav-icon">🏷️</span>
                        <span>Категории</span>
                    </a>
                </div>

                <div class="sidebar-footer">
                    <div class="user-info">
                        <span class="user-email">@context.User.Identity?.Name</span>
                    </div>
                    <button class="logout-btn" @onclick="Logout">
                        <span class="nav-icon">🚪</span>
                        <span>Выйти</span>
                    </button>
                </div>
            </nav>

            <main class="main-content">
                <div class="content">
                    @Body
                </div>
            </main>
        </div>
    </Authorized>
    <NotAuthorized>
        <div class="auth-layout">
            <header class="auth-header">
                <div class="logo">💰 MoneyTree</div>
                <div class="auth-links">
                    <a href="/login" class="auth-link">Вход</a>
                    <a href="/register" class="auth-link register">Регистрация</a>
                </div>
            </header>
            <div class="content">
                @Body
            </div>
        </div>
    </NotAuthorized>
</AuthorizeView>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    [Inject] private AuthService AuthService { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private async Task Logout()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/login", forceLoad: true);
    }
}
